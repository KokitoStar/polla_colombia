    <div class="pozo-item"><div class="pozo-label">Pozo Goleador</div><div class="pozo-val" id="pz-gol">$0</div></div>
    <div class="pozo-divider"></div>
    <div class="pozo-item" style="margin-left:auto;"><div class="pozo-label">💰 Pozo Total</div><div class="pozo-val big" id="pz-total">$0</div></div>
  </div>
</div>

