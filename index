<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>🇨🇴 Polla Futbolera Colombia</title>
<link href="https://fonts.googleapis.com/css2?family=Oswald:wght@400;600;700&family=Inter:wght@400;500;600;700&family=Share+Tech+Mono&display=swap" rel="stylesheet">
<style>
:root{--amarillo:#FCD116;--azul:#003893;--rojo:#CE1126;--carbon:#0a0a1a;--humo:#12122a;--humo2:#1a1a3e;--blanco:#fff;--gris:#8888aa;--verde:#00ff88;--naranja:#ff9900;}
*{box-sizing:border-box;margin:0;padding:0;}
body{background:var(--carbon);font-family:'Inter',sans-serif;color:var(--blanco);min-height:100vh;overflow-x:hidden;}

/* ── HEADER ── */
.tricolor{display:flex;height:7px;}
.tricolor span:nth-child(1){background:var(--amarillo);flex:2;}
.tricolor span:nth-child(2){background:var(--azul);flex:1;}
.tricolor span:nth-child(3){background:var(--rojo);flex:1;}
.header-inner{display:flex;align-items:center;justify-content:space-between;padding:16px 36px;background:linear-gradient(135deg,#001a5a,#003893,#001a5a);position:relative;overflow:hidden;}
.header-inner::before{content:'';position:absolute;inset:0;background:repeating-linear-gradient(45deg,transparent,transparent 28px,rgba(255,255,255,.02) 28px,rgba(255,255,255,.02) 30px);}
.header-logo{display:flex;align-items:center;gap:16px;z-index:1;}
.escudo{width:60px;height:60px;flex-shrink:0;}
.header-title h1{font-family:'Oswald',sans-serif;font-size:1.8rem;font-weight:700;letter-spacing:2px;text-transform:uppercase;text-shadow:0 2px 8px rgba(0,0,0,.5);line-height:1;}
.header-title h1 span{color:var(--amarillo);}
.header-title p{font-size:.72rem;color:rgba(255,255,255,.55);letter-spacing:3px;text-transform:uppercase;margin-top:3px;}

/* ── TABS ── */
.tabs{display:flex;background:var(--humo);border-bottom:3px solid var(--azul);}
.tab-btn{flex:1;padding:13px 20px;background:none;border:none;color:var(--gris);font-family:'Oswald',sans-serif;font-size:.9rem;font-weight:600;letter-spacing:2px;text-transform:uppercase;cursor:pointer;transition:all .2s;position:relative;}
.tab-btn:hover{color:var(--blanco);}
.tab-btn.active{color:var(--amarillo);}
.tab-btn.active::after{content:'';position:absolute;bottom:-3px;left:0;right:0;height:3px;background:var(--amarillo);}
.tab-content{display:none;}
.tab-content.active{display:block;}

/* ── CONFIG PANEL ── */
.config-panel{background:var(--humo);border-bottom:1px solid rgba(255,255,255,.07);padding:18px 32px;}
.config-title{font-family:'Oswald',sans-serif;font-size:.78rem;letter-spacing:3px;text-transform:uppercase;color:var(--amarillo);margin-bottom:12px;}
.config-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(190px,1fr));gap:14px;align-items:end;}
.cfg-item{display:flex;flex-direction:column;gap:5px;}
.cfg-label{font-size:.68rem;letter-spacing:1px;text-transform:uppercase;color:var(--gris);}
.cfg-input{background:var(--humo2);border:2px solid rgba(255,255,255,.1);border-radius:8px;padding:9px 12px;color:var(--blanco);font-family:'Oswald',sans-serif;font-size:1.1rem;font-weight:600;outline:none;transition:border-color .2s;width:100%;}
.cfg-input:focus{border-color:var(--amarillo);}

/* checkboxes tipo botón */
.check-group{display:flex;flex-wrap:wrap;gap:6px;}
.chk-btn{padding:6px 12px;border:2px solid rgba(255,255,255,.12);border-radius:7px;background:transparent;color:var(--gris);font-family:'Oswald',sans-serif;font-size:.78rem;font-weight:600;letter-spacing:1px;cursor:pointer;transition:all .2s;user-select:none;}
.chk-btn.on-favor  {border-color:var(--verde);color:var(--verde);background:rgba(0,255,136,.08);}
.chk-btn.on-empate {border-color:var(--amarillo);color:var(--amarillo);background:rgba(252,209,22,.08);}
.chk-btn.on-contra {border-color:var(--rojo);color:var(--rojo);background:rgba(206,17,38,.08);}
.chk-btn:hover{border-color:rgba(255,255,255,.3);color:var(--blanco);}

.btn-aplicar{padding:10px 22px;border:none;border-radius:8px;background:linear-gradient(135deg,var(--amarillo),#e6b800);color:#111;font-family:'Oswald',sans-serif;font-size:.95rem;font-weight:700;letter-spacing:1px;text-transform:uppercase;cursor:pointer;transition:all .2s;white-space:nowrap;}
.btn-aplicar:hover{transform:translateY(-2px);box-shadow:0 6px 20px rgba(252,209,22,.3);}

/* bombo info */
.bombo-info{display:flex;gap:10px;margin-top:10px;flex-wrap:wrap;}
.bombo-chip{background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.1);border-radius:20px;padding:4px 12px;font-size:.75rem;color:rgba(255,255,255,.6);display:flex;align-items:center;gap:5px;}
.bombo-chip strong{font-family:'Share Tech Mono',monospace;font-size:.9rem;}
.bombo-chip.c-favor strong{color:var(--verde);}
.bombo-chip.c-empate strong{color:var(--amarillo);}
.bombo-chip.c-contra strong{color:var(--rojo);}
.resultados-preview{display:flex;flex-wrap:wrap;gap:4px;margin-top:8px;}
.res-chip{font-family:'Share Tech Mono',monospace;font-size:.7rem;padding:2px 7px;border-radius:5px;border:1px solid;}
.res-chip.favor{background:rgba(0,255,136,.07);border-color:rgba(0,255,136,.25);color:var(--verde);}
.res-chip.empate{background:rgba(252,209,22,.07);border-color:rgba(252,209,22,.25);color:var(--amarillo);}
.res-chip.contra{background:rgba(206,17,38,.07);border-color:rgba(206,17,38,.25);color:#ff6688;}

/* ── POZO BAR ── */
.pozo-bar{display:flex;gap:16px;background:rgba(0,0,0,.3);border-radius:10px;padding:10px 20px;margin:0 32px 0;border:1px solid rgba(255,255,255,.06);align-items:center;flex-wrap:wrap;}
.pozo-item{display:flex;flex-direction:column;}
.pozo-label{font-size:.6rem;letter-spacing:2px;text-transform:uppercase;color:var(--gris);}
.pozo-val{font-family:'Oswald',sans-serif;font-size:1.1rem;font-weight:700;color:var(--amarillo);}
.pozo-val.big{font-size:1.4rem;color:var(--verde);}
.pozo-divider{width:1px;background:rgba(255,255,255,.08);align-self:stretch;}

/* ── POLLAS GRID ── */
.pollas-grid{display:grid;grid-template-columns:1fr 1fr;gap:22px;padding:20px 32px;}

/* ── POLLA CARD ── */
.polla-card{background:var(--humo);border-radius:16px;overflow:hidden;border:1px solid rgba(255,255,255,.06);box-shadow:0 8px 40px rgba(0,0,0,.4);}
.polla-header{padding:15px 20px;display:flex;align-items:center;justify-content:space-between;position:relative;overflow:hidden;}
.polla-header.resultado{background:linear-gradient(135deg,#1a0010,#3d0015,var(--rojo));}
.polla-header.goleador{background:linear-gradient(135deg,#001220,#002050,var(--azul));}
.polla-header::after{content:'';position:absolute;inset:0;background:repeating-linear-gradient(-45deg,transparent,transparent 8px,rgba(0,0,0,.1) 8px,rgba(0,0,0,.1) 9px);}
.polla-title-area{z-index:1;}
.polla-type{font-size:.6rem;letter-spacing:3px;text-transform:uppercase;color:rgba(255,255,255,.55);}
.polla-title{font-family:'Oswald',sans-serif;font-size:1.45rem;font-weight:700;letter-spacing:1px;text-transform:uppercase;line-height:1.1;}
.polla-sub{font-size:.67rem;color:rgba(255,255,255,.5);margin-top:2px;}
.polla-counter{z-index:1;background:rgba(0,0,0,.35);border-radius:10px;padding:8px 14px;text-align:center;backdrop-filter:blur(4px);}
.polla-counter .cnum{font-family:'Share Tech Mono',monospace;font-size:1.9rem;color:var(--amarillo);line-height:1;}
.polla-counter .clabel{font-size:.56rem;color:rgba(255,255,255,.55);letter-spacing:2px;text-transform:uppercase;}
.valor-badge{display:inline-flex;align-items:center;gap:4px;background:rgba(0,0,0,.3);border:1px solid rgba(252,209,22,.3);border-radius:6px;padding:3px 9px;font-family:'Oswald',sans-serif;font-size:.84rem;color:var(--amarillo);z-index:1;margin-top:3px;}

/* ── SORTEO AREA ── */
.sorteo-area{padding:18px;}
.marcador-display{background:#050510;border:2px solid rgba(255,255,255,.07);border-radius:12px;padding:16px;margin-bottom:14px;text-align:center;min-height:100px;display:flex;flex-direction:column;align-items:center;justify-content:center;position:relative;overflow:hidden;}
.scoreboard{display:flex;align-items:center;gap:10px;font-family:'Share Tech Mono',monospace;}
.score-team{display:flex;flex-direction:column;align-items:center;gap:2px;}
.score-num{font-size:3.6rem;color:var(--verde);text-shadow:0 0 18px rgba(0,255,136,.5);letter-spacing:3px;line-height:1;}
.score-num.amarillo{color:var(--amarillo);text-shadow:0 0 18px rgba(252,209,22,.4);}
.score-num.rojo{color:#ff4466;text-shadow:0 0 18px rgba(206,17,38,.4);}
.score-label{font-size:.58rem;letter-spacing:2px;color:var(--gris);text-transform:uppercase;font-family:'Inter',sans-serif;}
.score-sep{font-size:2.4rem;color:rgba(255,255,255,.2);line-height:1;margin:0 4px;}
.tipo-badge{font-size:.62rem;letter-spacing:2px;text-transform:uppercase;padding:2px 10px;border-radius:10px;font-weight:600;margin-top:4px;}
.tipo-badge.favor{background:rgba(0,255,136,.15);color:var(--verde);}
.tipo-badge.empate{background:rgba(252,209,22,.15);color:var(--amarillo);}
.tipo-badge.contra{background:rgba(206,17,38,.15);color:#ff4466;}
.idle-text{font-family:'Oswald',sans-serif;font-size:.9rem;color:rgba(255,255,255,.18);letter-spacing:3px;text-transform:uppercase;}

/* camiseta */
.camiseta-display{display:flex;flex-direction:column;align-items:center;gap:6px;}
.camiseta-svg{width:76px;height:76px;}
.camiseta-nombre{font-family:'Oswald',sans-serif;font-size:.9rem;font-weight:600;color:var(--blanco);letter-spacing:1px;text-align:center;}

/* spinner */
.spinner-overlay{display:none;position:absolute;inset:0;background:rgba(5,5,16,.93);z-index:10;align-items:center;justify-content:center;flex-direction:column;gap:6px;border-radius:12px;}
.spinner-overlay.show{display:flex;}
.spinner-nums{font-family:'Share Tech Mono',monospace;font-size:2.8rem;color:var(--verde);text-shadow:0 0 18px rgba(0,255,136,.6);letter-spacing:4px;line-height:1;}
.spinner-nums.shirt{font-family:'Oswald',sans-serif;font-size:2.6rem;color:var(--amarillo);text-shadow:0 0 18px rgba(252,209,22,.6);}
.spinner-label{font-family:'Oswald',sans-serif;font-size:.68rem;letter-spacing:3px;color:var(--gris);text-transform:uppercase;}
@keyframes pop{from{transform:scale(.7);opacity:0}to{transform:scale(1);opacity:1}}
.revealed{animation:pop .4s cubic-bezier(.34,1.56,.64,1);}
@keyframes slideIn{from{opacity:0;transform:translateY(-5px)}to{opacity:1;transform:translateY(0)}}

/* form */
.sorteo-form{display:flex;gap:8px;margin-bottom:12px;}
.nombre-input{flex:1;background:var(--humo2);border:2px solid rgba(255,255,255,.1);border-radius:8px;padding:10px 13px;color:var(--blanco);font-family:'Inter',sans-serif;font-size:.9rem;transition:border-color .2s;outline:none;}
.nombre-input:focus{border-color:var(--amarillo);}
.nombre-input::placeholder{color:var(--gris);}
.btn-sortear{padding:10px 18px;border:none;border-radius:8px;font-family:'Oswald',sans-serif;font-size:.9rem;font-weight:600;letter-spacing:1px;text-transform:uppercase;cursor:pointer;transition:all .2s;white-space:nowrap;}
.btn-sortear.resultado{background:linear-gradient(135deg,var(--rojo),#ff1a3d);color:#fff;box-shadow:0 4px 14px rgba(206,17,38,.4);}
.btn-sortear.resultado:hover:not(:disabled){transform:translateY(-2px);box-shadow:0 8px 22px rgba(206,17,38,.5);}
.btn-sortear.goleador{background:linear-gradient(135deg,var(--azul),#0055cc);color:#fff;box-shadow:0 4px 14px rgba(0,56,147,.4);}
.btn-sortear.goleador:hover:not(:disabled){transform:translateY(-2px);box-shadow:0 8px 22px rgba(0,56,147,.5);}
.btn-sortear:disabled{opacity:.4;cursor:not-allowed;transform:none;}
.error-msg{background:rgba(206,17,38,.15);border:1px solid rgba(206,17,38,.4);border-radius:6px;padding:7px 12px;font-size:.78rem;color:#ff6680;margin-bottom:10px;display:none;}
.error-msg.show{display:block;}
.agotado-badge{background:rgba(206,17,38,.15);border:1px solid var(--rojo);color:var(--rojo);font-family:'Oswald',sans-serif;font-size:.75rem;letter-spacing:2px;text-transform:uppercase;padding:6px 12px;border-radius:6px;margin-bottom:10px;display:none;text-align:center;}
.agotado-badge.show{display:block;}

/* lista */
.lista-title{font-family:'Oswald',sans-serif;font-size:.73rem;letter-spacing:2px;text-transform:uppercase;color:var(--gris);margin-bottom:7px;border-top:1px solid rgba(255,255,255,.07);padding-top:12px;}
.lista-asignados{max-height:200px;overflow-y:auto;display:flex;flex-direction:column;gap:4px;}
.lista-asignados::-webkit-scrollbar{width:3px;}
.lista-asignados::-webkit-scrollbar-thumb{background:rgba(255,255,255,.15);border-radius:3px;}
.asignado-item{display:flex;align-items:center;justify-content:space-between;background:rgba(255,255,255,.04);border-radius:7px;padding:7px 11px;border:1px solid rgba(255,255,255,.05);animation:slideIn .3s ease;gap:8px;}
.asig-nombre{font-weight:600;font-size:.82rem;color:var(--blanco);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:120px;}
.asig-res{font-family:'Share Tech Mono',monospace;font-size:.88rem;letter-spacing:1px;white-space:nowrap;}
.asig-res.favor{color:var(--verde);}
.asig-res.empate{color:var(--amarillo);}
.asig-res.contra{color:#ff4466;}
.asig-jug{display:flex;align-items:center;gap:5px;font-size:.8rem;}
.jug-badge{background:var(--azul);color:var(--amarillo);font-family:'Oswald',sans-serif;font-weight:700;font-size:.75rem;width:22px;height:22px;border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.lista-vacia{text-align:center;color:var(--gris);font-size:.78rem;padding:14px;font-style:italic;}

/* ── PLANTEL TAB ── */
.plantel-container{padding:22px 32px;}
.plantel-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;flex-wrap:wrap;gap:10px;}
.plantel-header h2{font-family:'Oswald',sans-serif;font-size:1.4rem;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--amarillo);}
.plantel-stats{display:flex;gap:10px;flex-wrap:wrap;}
.pstat{background:var(--humo2);border-radius:8px;padding:7px 14px;text-align:center;}
.pstat .psn{font-family:'Share Tech Mono',monospace;font-size:1.25rem;color:var(--verde);}
.pstat .psl{font-size:.6rem;color:var(--gris);letter-spacing:2px;text-transform:uppercase;}

/* instrucción titulares */
.plantel-instruccion{background:rgba(252,209,22,.07);border:1px solid rgba(252,209,22,.2);border-radius:10px;padding:12px 18px;margin-bottom:16px;font-size:.82rem;color:rgba(255,255,255,.7);line-height:1.5;}
.plantel-instruccion strong{color:var(--amarillo);}
.titulares-counter{font-family:'Oswald',sans-serif;font-size:1rem;font-weight:700;display:inline-block;padding:3px 12px;border-radius:20px;margin-left:8px;}
.titulares-counter.ok{background:rgba(0,255,136,.15);color:var(--verde);}
.titulares-counter.no{background:rgba(252,209,22,.15);color:var(--amarillo);}
.titulares-counter.over{background:rgba(206,17,38,.2);color:#ff4466;}

.plantel-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(148px,1fr));gap:10px;}

/* jugador card */
.jugador-card{background:var(--humo2);border-radius:12px;padding:13px 11px;text-align:center;border:2px solid rgba(255,255,255,.07);transition:all .25s;position:relative;overflow:hidden;cursor:pointer;user-select:none;}
.jugador-card:hover{border-color:rgba(252,209,22,.4);transform:translateY(-2px);}

/* estados */
.jugador-card.titular{border-color:var(--amarillo);background:rgba(252,209,22,.08);}
.jugador-card.titular .jc-dorsal{color:var(--amarillo);}
.jugador-card.suplente{opacity:.55;}
.jugador-card.asignado-gol{border-color:rgba(0,255,136,.3);background:rgba(0,255,136,.05);opacity:.8;}
.jugador-card.asignado-gol .jc-dorsal{color:var(--verde);}

.titular-marca{position:absolute;top:6px;right:6px;width:20px;height:20px;background:var(--amarillo);color:#111;border-radius:50%;display:none;align-items:center;justify-content:center;font-size:.65rem;font-weight:700;font-family:'Oswald',sans-serif;}
.jugador-card.titular .titular-marca{display:flex;}
.asignado-marca{position:absolute;top:6px;left:6px;width:18px;height:18px;background:var(--verde);color:#111;border-radius:50%;display:none;align-items:center;justify-content:center;font-size:.6rem;font-weight:700;}
.jugador-card.asignado-gol .asignado-marca{display:flex;}

.jc-dorsal{font-family:'Oswald',sans-serif;font-size:2rem;font-weight:700;color:rgba(255,255,255,.35);line-height:1;margin-bottom:4px;transition:color .2s;}
.jugador-card.disponible-gol .jc-dorsal{color:rgba(255,255,255,.6);}
.jc-nombre{font-size:.73rem;font-weight:600;color:var(--blanco);line-height:1.3;margin-bottom:3px;}
.jc-pos{font-size:.6rem;color:var(--gris);letter-spacing:1px;margin-bottom:3px;}
.jc-asig-a{font-size:.63rem;color:var(--verde);font-style:italic;background:rgba(0,255,136,.1);border-radius:4px;padding:2px 5px;display:none;}
.jugador-card.asignado-gol .jc-asig-a{display:block;}
.jc-hint{font-size:.6rem;color:rgba(255,255,255,.25);margin-top:2px;}
.jugador-card.titular .jc-hint{color:var(--amarillo);opacity:.7;}

/* ── TOOLBAR ── */
.toolbar{display:flex;justify-content:center;padding:12px 32px;background:var(--humo);border-top:1px solid rgba(255,255,255,.06);}
.btn-reiniciar{background:transparent;border:2px solid rgba(206,17,38,.4);color:rgba(206,17,38,.75);padding:9px 24px;border-radius:8px;font-family:'Oswald',sans-serif;font-size:.86rem;font-weight:600;letter-spacing:2px;text-transform:uppercase;cursor:pointer;transition:all .2s;}
.btn-reiniciar:hover{background:var(--rojo);border-color:var(--rojo);color:#fff;box-shadow:0 4px 14px rgba(206,17,38,.4);}

/* ── MODAL ── */
.modal-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.75);z-index:1000;align-items:center;justify-content:center;backdrop-filter:blur(4px);}
.modal-overlay.show{display:flex;}
.modal-box{background:var(--humo2);border:2px solid var(--rojo);border-radius:16px;padding:30px 34px;text-align:center;max-width:360px;box-shadow:0 20px 60px rgba(206,17,38,.3);}
.modal-box h3{font-family:'Oswald',sans-serif;font-size:1.3rem;font-weight:700;letter-spacing:1px;text-transform:uppercase;color:var(--rojo);margin-bottom:10px;}
.modal-box p{font-size:.86rem;color:rgba(255,255,255,.65);margin-bottom:20px;line-height:1.5;}
.modal-btns{display:flex;gap:10px;justify-content:center;}
.btn-confirm{background:var(--rojo);color:#fff;border:none;padding:9px 22px;border-radius:8px;font-family:'Oswald',sans-serif;font-size:.9rem;font-weight:600;letter-spacing:1px;cursor:pointer;}
.btn-cancel{background:transparent;border:2px solid rgba(255,255,255,.2);color:rgba(255,255,255,.65);padding:9px 22px;border-radius:8px;font-family:'Oswald',sans-serif;font-size:.9rem;cursor:pointer;}

/* spacing util */
.mt8{margin-top:8px;}
.mb0{margin-bottom:0;}
</style>
</head>
<body>

<!-- HEADER -->
<div style="background:var(--azul);">
  <div class="tricolor"><span></span><span></span><span></span></div>
  <div class="header-inner">
    <div class="header-logo">
      <div class="escudo">
        <svg viewBox="0 0 60 60" fill="none" xmlns="http://www.w3.org/2000/svg">
          <defs><clipPath id="sh"><path d="M30 3L54 14L54 35Q54 50 30 57Q6 50 6 35L6 14Z"/></clipPath></defs>
          <path d="M30 3L54 14L54 35Q54 50 30 57Q6 50 6 35L6 14Z" fill="#002870"/>
          <rect x="6" y="14" width="48" height="14" fill="#FCD116" clip-path="url(#sh)"/>
          <rect x="6" y="28" width="48" height="10" fill="#003893" clip-path="url(#sh)"/>
          <rect x="6" y="38" width="48" height="19" fill="#CE1126" clip-path="url(#sh)"/>
          <path d="M30 3L54 14L54 35Q54 50 30 57Q6 50 6 35L6 14Z" fill="none" stroke="rgba(255,255,255,.2)" stroke-width="1.5"/>
          <text x="30" y="27" text-anchor="middle" font-family="Oswald,sans-serif" font-size="9" font-weight="700" fill="#001a50">COL</text>
        </svg>
      </div>
      <div class="header-title">
        <h1>🏆 Polla <span>Colombia</span></h1>
        <p>Sistema de sorteo futbolero · Tricolor</p>
      </div>
    </div>
  </div>
  <div class="tricolor"><span></span><span></span><span></span></div>
</div>

<!-- TABS -->
<div class="tabs">
  <button class="tab-btn active" onclick="showTab('pollas',this)">⚽ Las Dos Pollas</button>
  <button class="tab-btn" onclick="showTab('plantel',this)">👕 Plantel & Titulares</button>
</div>

<!-- CONFIG -->
<div class="config-panel">
  <div class="config-title">⚙ Configuración del sorteo</div>
  <div class="config-grid">

    <div class="cfg-item">
      <div class="cfg-label">Tipos de resultado a incluir</div>
      <div class="check-group">
        <button class="chk-btn on-favor" id="chk-favor" onclick="toggleTipo('favor')">🏆 A favor</button>
        <button class="chk-btn on-empate" id="chk-empate" onclick="toggleTipo('empate')">🤝 Empate</button>
        <button class="chk-btn" id="chk-contra" onclick="toggleTipo('contra')">😬 En contra</button>
      </div>
    </div>

    <div class="cfg-item">
      <div class="cfg-label">Máximo goles (ej: 4 → resultados hasta 4-0, 0-4)</div>
      <input type="number" class="cfg-input" id="cfg-max" value="4" min="1" max="20" style="max-width:110px;">
    </div>

    <div class="cfg-item">
      <div class="cfg-label">Valor polla Resultado ($)</div>
      <input type="number" class="cfg-input" id="cfg-vres" value="5000" min="0" step="1000">
    </div>

    <div class="cfg-item">
      <div class="cfg-label">Valor polla Goleador ($)</div>
      <input type="number" class="cfg-input" id="cfg-vgol" value="5000" min="0" step="1000">
    </div>

    <div class="cfg-item" style="justify-content:flex-end;">
      <button class="btn-aplicar" onclick="aplicarConfig()">✔ Aplicar</button>
