<script>
// ══════════════════════════════════════
// PLANTEL — editable aquí
// ══════════════════════════════════════
const JUGADORES = [
  {num:1,  nombre:"Camilo Vargas",       pos:"GK"},
  {num:2,  nombre:"Daniel Muñoz",         pos:"DEF"},
  {num:3,  nombre:"Jhon Lucumí",          pos:"DEF"},
  {num:4,  nombre:"Santiago Arias",       pos:"DEF"},
  {num:5,  nombre:"William Tesillo",      pos:"DEF"},
  {num:6,  nombre:"Kevin Castaño",        pos:"MED"},
  {num:7,  nombre:"Luis Díaz",            pos:"DEL"},
  {num:8,  nombre:"Richard Ríos",         pos:"MED"},
  {num:9,  nombre:"Rafael Santos Borré",  pos:"DEL"},
  {num:10, nombre:"James Rodríguez",      pos:"MED"},
  {num:11, nombre:"Jhon Arias",           pos:"DEL"},
  {num:12, nombre:"Camilo Vargas (G)",    pos:"GK"},
  {num:13, nombre:"Yerry Mina",           pos:"DEF"},
  {num:14, nombre:"Gustavo Puerta",       pos:"MED"},
  {num:15, nombre:"Jhon Jáder Durán",     pos:"DEL"},
  {num:16, nombre:"Jefferson Lerma",      pos:"MED"},
  {num:17, nombre:"Johan Mojica",         pos:"DEF"},
  {num:18, nombre:"Daniel Ruiz",          pos:"MED"},
  {num:19, nombre:"Mateo Castillo",       pos:"MED"},
  {num:20, nombre:"Jorge Carrascal",      pos:"MED"},
  {num:21, nombre:"Roger Martínez",       pos:"DEL"},
  {num:22, nombre:"Kevin Mier",           pos:"GK"},
  {num:23, nombre:"Dávinson Sánchez",     pos:"DEF"},
  {num:24, nombre:"Carlos Cuesta",        pos:"DEF"},
  {num:25, nombre:"Luis Suárez",          pos:"MED"},
  {num:26, nombre:"Néiser Villarreal",    pos:"MED"},
];

// ══════════════════════════════════════
// ESTADO
// ══════════════════════════════════════
let tiposActivos = {favor:true, empate:true, contra:false};
let maxGoles = 4;
let valorRes = 5000, valorGol = 5000;

// Set de índices titulares (máx 11)
let titulares = new Set();
// true = usar solo titulares, false = todos
let usarTitulares = false;

let bomboRes = [];
let bomboGol = [];
let asigRes = [];
let asigGol = [];
let sortRes = false, sortGol = false;

// ══════════════════════════════════════
// TITULARES — click en plantel
// ══════════════════════════════════════
function toggleTitular(idx) {
  if (titulares.has(idx)) {
    titulares.delete(idx);
  } else {
    if (titulares.size >= 11) {
      // no dejar agregar más de 11
      return;
    }
    titulares.add(idx);
  }
  actualizarContadorTitulares();
  renderPlantel();
}

function actualizarContadorTitulares() {
  const n = titulares.size;
  const el = document.getElementById('tit-counter');
  el.textContent = n + ' / 11';
  el.className = 'titulares-counter ' + (n === 11 ? 'ok' : n > 11 ? 'over' : 'no');
  document.getElementById('pl-tit').textContent = n;
}

// ══════════════════════════════════════
// TIPOS DE RESULTADO
// ══════════════════════════════════════
function toggleTipo(tipo) {
  tiposActivos[tipo] = !tiposActivos[tipo];
  const btn = document.getElementById('chk-' + tipo);
  if (tiposActivos[tipo]) {
    btn.classList.add('on-' + tipo);
  } else {
    btn.classList.remove('on-' + tipo);
  }
}

// ══════════════════════════════════════
// GENERAR RESULTADOS
// ══════════════════════════════════════
function generarResultados(max, tipos) {
  const lista = [];
  if (tipos.favor) {
    for (let f = 1; f <= max; f++)
      for (let c = 0; c < f; c++)
        lista.push({favor:f, contra:c, tipo:'favor'});
  }
  if (tipos.empate) {
    for (let g = 0; g <= max; g++)
      lista.push({favor:g, contra:g, tipo:'empate'});
  }
  if (tipos.contra) {
    for (let c = 1; c <= max; c++)
      for (let f = 0; f < c; f++)
        lista.push({favor:f, contra:c, tipo:'contra'});
  }
  return lista;
}

// ══════════════════════════════════════
// APLICAR CONFIG
// ══════════════════════════════════════
function aplicarConfig() {
  maxGoles = parseInt(document.getElementById('cfg-max').value) || 4;
  maxGoles = Math.max(1, Math.min(20, maxGoles));
  valorRes = parseInt(document.getElementById('cfg-vres').value) || 0;
  valorGol = parseInt(document.getElementById('cfg-vgol').value) || 0;

  // Determinar si usar titulares
  usarTitulares = titulares.size === 11;

  reiniciarBombos();
  actualizarPreview();
  actualizarUI();
}

function actualizarPreview() {
  const todos = generarResultados(maxGoles, tiposActivos);
  const favor = todos.filter(r=>r.tipo==='favor').length;
  const empate = todos.filter(r=>r.tipo==='empate').length;
  const contra = todos.filter(r=>r.tipo==='contra').length;

  document.getElementById('info-favor').textContent = favor;
  document.getElementById('info-empate').textContent = empate;
  document.getElementById('info-contra').textContent = contra;
  document.getElementById('info-total').textContent = todos.length;

  const preview = document.getElementById('res-preview');
  preview.innerHTML = todos.map(r =>
    `<span class="res-chip ${r.tipo}">${r.favor}-${r.contra}</span>`
  ).join('');

  // Sub-texto
  const partes = [];
  if (tiposActivos.favor) partes.push('🏆 A favor');
  if (tiposActivos.empate) partes.push('🤝 Empates');
  if (tiposActivos.contra) partes.push('😬 En contra');
  document.getElementById('sub-modo').textContent = partes.join(' · ') || 'Sin tipos seleccionados';

  // Goleador sub
  document.getElementById('sub-gol').textContent = usarTitulares
    ? '11 Titular seleccionado'
    : 'Plantel completo (26)';

  // Badges valor
  document.getElementById('badge-vres').textContent = '💵 $' + valorRes.toLocaleString('es-CO') + ' por puesto';
  document.getElementById('badge-vgol').textContent = '💵 $' + valorGol.toLocaleString('es-CO') + ' por puesto';
}

// ══════════════════════════════════════
// REINICIAR BOMBOS
// ══════════════════════════════════════
function reiniciarBombos() {
  const lista = generarResultados(maxGoles, tiposActivos);
  shuffle(lista);
  bomboRes = lista;

  // Goleador: titulares o todos
  if (usarTitulares && titulares.size === 11) {
    bomboGol = [...titulares];
  } else {
    bomboGol = JUGADORES.map((_,i)=>i);
  }
  shuffle(bomboGol);

  asigRes = [];
  asigGol = [];

  // Resetear UI
  ['agot-res','agot-gol'].forEach(id=>document.getElementById(id).classList.remove('show'));
  document.getElementById('btn-res').disabled = false;
  document.getElementById('btn-gol').disabled = false;
  document.getElementById('res-content').innerHTML = '<div class="idle-text">Esperando sorteo</div>';
  document.getElementById('gol-content').innerHTML = '<div class="idle-text">Esperando sorteo</div>';
}

function shuffle(a) {
  for (let i=a.length-1;i>0;i--){const j=Math.floor(Math.random()*(i+1));[a[i],a[j]]=[a[j],a[i]];}
}

// ══════════════════════════════════════
// TABS
// ══════════════════════════════════════
function showTab(tab, btn) {
  document.querySelectorAll('.tab-content').forEach(el=>el.classList.remove('active'));
  document.querySelectorAll('.tab-btn').forEach(el=>el.classList.remove('active'));
  document.getElementById('tab-'+tab).classList.add('active');
  btn.classList.add('active');
  if (tab==='plantel') renderPlantel();
}

// ══════════════════════════════════════
// SORTEO RESULTADO
// ══════════════════════════════════════
function sortearResultado() {
  if (sortRes) return;
  const input = document.getElementById('nom-res');
  const nombre = input.value.trim();
  const errEl = document.getElementById('err-res');
  errEl.classList.remove('show');

  if (!nombre) { mostrarError(errEl,'Escribe el nombre del participante.'); return; }
  if (asigRes.some(a=>a.nombre.toLowerCase()===nombre.toLowerCase()))
    { mostrarError(errEl,`"${nombre}" ya tiene un resultado asignado.`); return; }
  if (bomboRes.length===0) { mostrarError(errEl,'El bombo está vacío.'); return; }

  sortRes = true;
  document.getElementById('btn-res').disabled = true;
  document.getElementById('spin-res').classList.add('show');

  const spinEl = document.getElementById('spin-res-n');
  const todos = generarResultados(maxGoles, tiposActivos);
  const ref = todos.length ? todos : [{favor:0,contra:0,tipo:'empate'}];

  const iv = setInterval(()=>{
    const r = ref[Math.floor(Math.random()*ref.length)];
    spinEl.textContent = `${r.favor} — ${r.contra}`;
  }, 80);

  setTimeout(()=>{
    clearInterval(iv);
    document.getElementById('spin-res').classList.remove('show');
    const res = bomboRes.pop();
    asigRes.push({nombre, ...res});
    mostrarResDisplay(res);
    input.value = '';
    sortRes = false;
    if (bomboRes.length > 0) document.getElementById('btn-res').disabled = false;
    actualizarUI();
  }, 1600);
}

function mostrarResDisplay(res) {
  const cls = res.tipo === 'favor' ? '' : res.tipo === 'empate' ? 'amarillo' : 'rojo';
  const etiqueta = {favor:'🏆 Victoria Colombia', empate:'🤝 Empate', contra:'😬 Derrota Colombia'}[res.tipo];
  document.getElementById('res-content').innerHTML = `
    <div class="scoreboard revealed">
      <div class="score-team">
        <div class="score-num ${cls}">${res.favor}</div>
        <div class="score-label">🇨🇴 Colombia</div>
      </div>
      <div class="score-sep">–</div>
      <div class="score-team">
        <div class="score-num ${cls}">${res.contra}</div>
        <div class="score-label">Rival</div>
      </div>
    </div>
    <div class="tipo-badge ${res.tipo}">${etiqueta}</div>
  `;
}

// ══════════════════════════════════════
// SORTEO GOLEADOR
// ══════════════════════════════════════
function sortearGoleador() {
  if (sortGol) return;
  const input = document.getElementById('nom-gol');
  const nombre = input.value.trim();
  const errEl = document.getElementById('err-gol');
  errEl.classList.remove('show');

  if (!nombre) { mostrarError(errEl,'Escribe el nombre del participante.'); return; }
  if (asigGol.some(a=>a.nombre.toLowerCase()===nombre.toLowerCase()))
    { mostrarError(errEl,`"${nombre}" ya tiene un jugador asignado.`); return; }
  if (bomboGol.length===0) { mostrarError(errEl,'El bombo está vacío.'); return; }

  sortGol = true;
  document.getElementById('btn-gol').disabled = true;
  document.getElementById('spin-gol').classList.add('show');

  const spinEl = document.getElementById('spin-gol-n');
  const pool = usarTitulares ? [...titulares] : JUGADORES.map((_,i)=>i);

  const iv = setInterval(()=>{
    const ri = pool[Math.floor(Math.random()*pool.length)];
    spinEl.textContent = '#' + JUGADORES[ri].num;
  }, 80);

  setTimeout(()=>{
    clearInterval(iv);
    document.getElementById('spin-gol').classList.remove('show');
    const idx = bomboGol.pop();
    asigGol.push({nombre, jugadorIdx:idx});
    mostrarGolDisplay(idx);
    input.value = '';
    sortGol = false;
    if (bomboGol.length > 0) document.getElementById('btn-gol').disabled = false;
    actualizarUI();
  }, 1600);
}

function mostrarGolDisplay(idx) {
  const j = JUGADORES[idx];
  document.getElementById('gol-content').innerHTML = `
    <div class="camiseta-display revealed">
      ${camisetaSVG(j.num)}
      <div class="camiseta-nombre">${j.nombre}</div>
    </div>
  `;
}

function camisetaSVG(num) {
  return `<svg class="camiseta-svg" viewBox="0 0 80 80" xmlns="http://www.w3.org/2000/svg">
    <polygon points="10,20 25,10 30,20 50,20 55,10 70,20 65,70 15,70" fill="#FCD116" stroke="#003893" stroke-width="2"/>
    <ellipse cx="40" cy="20" rx="10" ry="6" fill="#003893"/>
    <polygon points="10,20 5,38 18,38 25,20" fill="#CE1126"/>
    <polygon points="70,20 75,38 62,38 55,20" fill="#CE1126"/>
    <text x="40" y="52" text-anchor="middle" font-family="Oswald,sans-serif" font-size="${num>=10?'18':'22'}" font-weight="700" fill="#003893">${num}</text>
  </svg>`;
}

// ══════════════════════════════════════
// UI UPDATE
// ══════════════════════════════════════
function actualizarUI() {
  document.getElementById('cnt-res').textContent = bomboRes.length;
  document.getElementById('cnt-gol').textContent = bomboGol.length;

  if (bomboRes.length===0) { document.getElementById('agot-res').classList.add('show'); document.getElementById('btn-res').disabled=true; }
  if (bomboGol.length===0) { document.getElementById('agot-gol').classList.add('show'); document.getElementById('btn-gol').disabled=true; }

  renderListaRes();
  renderListaGol();

  document.getElementById('lt-res').textContent = `📋 Asignaciones (${asigRes.length})`;
  document.getElementById('lt-gol').textContent = `📋 Asignaciones (${asigGol.length})`;

  // Pozo
  const pRes = asigRes.length, pGol = asigGol.length;
  const pozRes = pRes*valorRes, pozGol = pGol*valorGol;
  document.getElementById('pz-pres').textContent = pRes;
  document.getElementById('pz-pgol').textContent = pGol;
  document.getElementById('pz-res').textContent = '$'+pozRes.toLocaleString('es-CO');
  document.getElementById('pz-gol').textContent = '$'+pozGol.toLocaleString('es-CO');
  document.getElementById('pz-total').textContent = '$'+(pozRes+pozGol).toLocaleString('es-CO');

  // Plantel stats
  document.getElementById('pl-disp').textContent = bomboGol.length;
  document.getElementById('pl-asig').textContent = asigGol.length;
}

function renderListaRes() {
  const el = document.getElementById('lista-res');
  if (!asigRes.length) { el.innerHTML='<div class="lista-vacia">Aún no hay asignaciones...</div>'; return; }
  el.innerHTML = [...asigRes].reverse().map(a=>`
    <div class="asignado-item">
      <span class="asig-nombre">👤 ${esc(a.nombre)}</span>
      <span class="asig-res ${a.tipo}">${a.favor}–${a.contra} ${{favor:'🏆',empate:'🤝',contra:'😬'}[a.tipo]}</span>
    </div>`).join('');
}

function renderListaGol() {
  const el = document.getElementById('lista-gol');
  if (!asigGol.length) { el.innerHTML='<div class="lista-vacia">Aún no hay asignaciones...</div>'; return; }
  el.innerHTML = [...asigGol].reverse().map(a=>{
    const j = JUGADORES[a.jugadorIdx];
    return `<div class="asignado-item">
      <span class="asig-nombre">👤 ${esc(a.nombre)}</span>
      <span class="asig-jug"><span class="jug-badge">${j.num}</span><span style="font-size:.8rem">${j.nombre}</span></span>
    </div>`;
  }).join('');
}

function renderPlantel() {
  const asigIdxs = new Set(asigGol.map(a=>a.jugadorIdx));
  const grid = document.getElementById('plantel-grid');
  grid.innerHTML = JUGADORES.map((j,i)=>{
    const esTitular = titulares.has(i);
    const esSuplente = titulares.size===11 && !esTitular;
    const asig = asigGol.find(a=>a.jugadorIdx===i);
    let cls = 'jugador-card';
    if (asig) cls += ' asignado-gol';
    else if (esTitular) cls += ' titular';
    else if (esSuplente) cls += ' suplente';

    return `<div class="${cls}" onclick="toggleTitular(${i})">
      <div class="titular-marca">11</div>
      <div class="asignado-marca">✓</div>
      <div class="jc-dorsal">${j.num}</div>
      <div class="jc-nombre">${j.nombre}</div>
      <div class="jc-pos">${j.pos}</div>
      <div class="jc-asig-a">${asig?esc(asig.nombre):''}</div>
      <div class="jc-hint">${esTitular?'★ Titular':'Clic para titular'}</div>
    </div>`;
  }).join('');

  actualizarContadorTitulares();
}

// ══════════════════════════════════════
