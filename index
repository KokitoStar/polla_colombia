  <div class="pozo-bar">
    <div class="pozo-item"><div class="pozo-label">Participantes Resultado</div><div class="pozo-val" id="pz-pres">0</div></div>
    <div class="pozo-divider"></div>
    <div class="pozo-item"><div class="pozo-label">Pozo Resultado</div><div class="pozo-val" id="pz-res">$0</div></div>
