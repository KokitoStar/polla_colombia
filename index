function pedirReinicio() { document.getElementById('modal').classList.add('show'); }
function cerrarModal() { document.getElementById('modal').classList.remove('show'); }
function confirmarReinicio() { cerrarModal(); reiniciarBombos(); actualizarUI(); }

// ══════════════════════════════════════
// UTILS
// ══════════════════════════════════════
function esc(s){return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');}
function mostrarError(el,msg){el.textContent=msg;el.classList.add('show');setTimeout(()=>el.classList.remove('show'),3200);}

// Enter keys
document.getElementById('nom-res').addEventListener('keydown',e=>{if(e.key==='Enter')sortearResultado();});
document.getElementById('nom-gol').addEventListener('keydown',e=>{if(e.key==='Enter')sortearGoleador();});
document.addEventListener('keydown',e=>{if(e.key==='Escape')cerrarModal();});

// ARRANQUE
aplicarConfig();
</script>
