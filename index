  </div>

  <div class="bombo-info">
    <div class="bombo-chip c-favor">A favor: <strong id="info-favor">—</strong></div>
    <div class="bombo-chip c-empate">Empates: <strong id="info-empate">—</strong></div>
    <div class="bombo-chip c-contra">En contra: <strong id="info-contra">—</strong></div>
    <div class="bombo-chip">Total bombo: <strong id="info-total">—</strong></div>
  </div>
  <div class="resultados-preview mt8" id="res-preview"></div>
</div>

<!-- POZO -->
